# Copy this file to ".env" (not ".env.local" — see README's Environment
# Variables section for why) and fill in real values.

# Client-safe config (inlined into the browser bundle by Vite — never put secrets here).
# Optional: override the backend base URL. Defaults to same-origin "/api".
# VITE_API_BASE_URL=/api

# Server-only secrets, read by the serverless functions in /api. These are
# NEVER exposed to the browser — do not prefix them with VITE_.
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_API_KEY_2=optional_fallback_key_for_rate_limit_resilience
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=google/gemini-2.0-flash
